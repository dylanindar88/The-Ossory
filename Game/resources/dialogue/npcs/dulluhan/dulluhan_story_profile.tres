[sub_resource type="Resource" id="DialogueSequence_unlock"]
script = ExtResource("3_sequence")
pages = Array[String](["The old shape in your blood is awake now.", "When the time comes, wear the wolf and the dead will stay dead.", "Return to the elder. They will know what this shape is for."])

