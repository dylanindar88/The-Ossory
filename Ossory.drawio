        <mxCell id="bGyFGWg-yUuXg434AnWw-9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=12;fillColor=#60a917;strokeColor=light-dark(#2D7600,#660033);fontColor=#ffffff;strokeWidth=7;" value="&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ellén Trechend – First Fight&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Location Change:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ossory → Forbidden Wilds (Regular World boundary)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Reason:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Guild assigns an “impossible hunt” to dispose of her&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Encounter: Boss fight (loss)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;First battle with Ellén Trechend&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Overwhelming defeat&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Near death&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Encounter: Dullahan appearance&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=