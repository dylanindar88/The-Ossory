        <mxCell id="4qypV36ItCKHLNTgIOiQ-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=12;fillColor=#97D077;fontColor=#ffffff;strokeColor=light-dark(#2D7600,#660033);strokeWidth=7;gradientColor=#B5739D;" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; font-size: 19px;&quot;&gt;&lt;b&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ellén Trechend – Final Battle&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Location: Threshold Before Final Battle&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Encounter: Strange hospitality&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Saoirse Refuses Rule&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Power Granted Anyway:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Equilibrium&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Uses incredible strength while low health to defeat fodder soldiers and chase the King&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="136" width="361" x="200" y="5366" as="geometry" />
        </mxCell>
        <mxCell id="4qypV36ItCKHLNTgIOiQ-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=12;strokeColor=light-dark(#2D7600,#660033);strokeWidth=7;" value="&lt;div&gt;&lt;span style=&quot;font-size: 19px;&quot;&gt;&lt;b&gt;Ending – The Refusal&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Location Change:&lt;/div&gt;&lt;div&gt;Veil Nexus → New Ossory&lt;/div&gt;&lt;div&gt;Encounter: Choice without combat&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Offered crown, knighthood, divinity&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Refuses all&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Leaves veil open to enforce what King Brian lied about doing, spreading the resources and prosperity of the otherworld&lt;/div&gt;&lt;div&gt;Final Image:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Saoirse returns to chosen life&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Dullahan continues watching with intrigue&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Morrigan silent but content&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="194" width="361" x="200" y="5514" as="geometry" />
        </mxCell>
        <mxCell id="4qypV36ItCKHLNTgIOiQ-26" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=12;fillColor=#b0e3e6;strokeColor=#0e8088;" value="&lt;div&gt;&lt;span style=&quot;font-size: 19px;&quot;&gt;&lt;b&gt;Feast of Bricriu&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Encounter: (Small town outside Eire called Dundrum)&lt;/div&gt;&lt;div&gt;Competition against Cu Chulainn, Conall Cernach and Loegaire&lt;/div&gt;&lt;div&gt;Turns out to be a trap to kill all heros present run by Chauns by order of King Brian&lt;/div&gt;&lt;div&gt;Must fight each hero to prove MC is strongest then fight waves of fodder with the help of the heroes&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Narrative Function:&lt;/div&gt;&lt;div&gt;Shows the new kings influence is impossible to avoid&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="154" width="361" x="200" y="3226" as="geometry" />
        </mxCell>
